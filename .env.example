# API (backend) URL - for REST API, stats, AI quiz/PDF, live games, reports
# Production (Vercel): set to your deployed backend, e.g. https://quizverse-6nxn.onrender.com
# Without this pointing to a running backend, AI + PDF generation and saved reports will not work in production.
VITE_API_URL=http://localhost:4000

# Socket.IO server URL - usually same as VITE_API_URL when backend hosts both.
# Production: same as VITE_API_URL (e.g. https://quizverse-6nxn.onrender.com)
VITE_SOCKET_URL=

# Google Analytics - Measurement ID from analytics.google.com
# Leave empty to disable GA
VITE_GA_ID=G-4X4ZXEY2XH

# Backend only (see backend/.env.example): OPENAI_API_KEY is required on the server for
# POST /api/ai/generate-quiz and POST /api/ai/pdf-to-quiz. Not a Vite variable.
