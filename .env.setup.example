# Copy to .env.setup and fill values. .env.setup is gitignored.
# Get MONGODB_URI: Atlas → Security → Database Access → Edit user → New password → Connect → Drivers → copy
# Add /quizverse before ? in the URI
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxx.mongodb.net/quizverse?retryWrites=true&w=majority

# Get from dashboard.render.com → Account Settings → API Keys
RENDER_API_KEY=

# From your Render service URL (default below)
RENDER_SERVICE_ID=srv-d6n3nn3h46gs73c1qa4g
