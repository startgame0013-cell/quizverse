PORT=4000
# MongoDB Atlas: Security → Database Access → Create user → Copy connection string
# Format: mongodb+srv://USER:PASSWORD@cluster.xxx.mongodb.net/quizverse?retryWrites=true&w=majority
# Replace <password> and ensure /quizverse before the ?
MONGODB_URI=mongodb://localhost:27017/quizverse

# IMPORTANT: Use a strong random secret in production (e.g. openssl rand -base64 32)
JWT_SECRET=your-super-secret-key-change-in-production

OPENAI_API_KEY=
FRONTEND_URL=https://quizverse-lyart.vercel.app

# Paddle (payment - supports Kuwait)
PADDLE_API_KEY=pdl_xxx
PADDLE_PRICE_BASIC=pri_xxx
PADDLE_PRICE_PRO=pri_xxx
PADDLE_PRICE_SCHOOL=pri_xxx
# PADDLE_SANDBOX=true  # for testing
